{
  "name": "little-q-desktop",
  "version": "1.0.0",
  "description": "This is an AI Agent Application.",
  "main": "./out/main/index.js",
  "author": "PYmili",
  "homepage": "https://pymili.github.io/",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts,.vue --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ electron-vite preview",
    "dev": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ electron-vite dev",
    "build": "npm run typecheck && cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ electron-vite build",
    "postinstall": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ electron-builder install-app-deps",
    "build:unpack": "npm run build && cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ electron-builder --dir",
    "build:win": "npm run build && cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ electron-builder --win",
    "build:mac": "npm run build && cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ electron-builder --mac",
    "build:linux": "npm run build && cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ electron-builder --linux"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/openai": "^3.0.67",
    "@electron-toolkit/preload": "3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@element-plus/icons-vue": "^2.3.2",
    "ai": "^6.0.193",
    "axios": "^1.16.1",
    "element-plus": "^2.14.1",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue-router": "^4.6.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "1.0.2",
    "@electron-toolkit/eslint-config-ts": "1.0.1",
    "@electron-toolkit/tsconfig": "1.0.1",
    "@rushstack/eslint-patch": "^1.7.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.15.3",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "cross-env": "^10.1.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-vue": "^9.20.1",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "7.3.3",
    "vue": "^3.4.15",
    "vue-tsc": "^1.8.27"
  }
}
